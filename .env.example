# Database
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASS=your-db-password
DB_NAME=spinners_payroll
DB_CONNECT_TIMEOUT_MS=10000
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA_PATH=

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=8h

# Server
PORT=3001
NODE_ENV=production

# OTP Settings
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
EMAIL_DEMO_MODE=false

# Company
COMPANY_NAME=Spinners Mattress Company
COMPANY_EMAIL=info@spinners.co.ke
COMPANY_EMAIL_DOMAIN=spinners.co.ke

# CORS
CORS_ORIGIN=https://your-project.vercel.app

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=Spinners Payroll <no-reply@spinners.co.ke>
